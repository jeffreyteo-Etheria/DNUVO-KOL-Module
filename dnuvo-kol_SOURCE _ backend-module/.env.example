# ── Copy to .env and fill after API approval (see API-APPLICATION-GUIDE.md) ──

# Anthropic API (used by backend /ai/generate proxy)
ANTHROPIC_API_KEY=

# Apify multi-actor KOL sourcing
APIFY_TOKEN=
APIFY_ACTOR_DISCOVERY=alizarin_refrigerator-owner/influencer-discovery---find-influencers-across-social-platforms
APIFY_ACTOR_TIKTOK=alizarin_refrigerator-owner/tiktok-creator-scraper
APIFY_ACTOR_INSTAGRAM=seemuapps/instagram-related-profiles-scraper
APIFY_WAIT_SECS=90
APIFY_SG_LOCAL_CONFIDENCE_MIN=0.70
APIFY_MIN_FOLLOWERS_NANO=1000
APIFY_MIN_FOLLOWERS_MICRO=25000
APIFY_MIN_FOLLOWERS_MID=100000
APIFY_MIN_FOLLOWERS_MACRO=500000
APIFY_MIN_FOLLOWERS_MEGA=1000000

# TikTok Content Posting API (https://developers.tiktok.com)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=        # user access token with video.publish scope

# Meta Graph API (https://developers.facebook.com)
META_APP_ID=
META_APP_SECRET=
META_PAGE_ID=               # Facebook Page ID
META_IG_USER_ID=            # Instagram Business account ID linked to the Page
META_ACCESS_TOKEN=          # long-lived Page token: pages_manage_posts, instagram_content_publish

# Server
PORT=3000
# SQLite database file is created automatically at data/pipeline.db
